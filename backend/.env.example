# =============================================
# VIBE Backend - Environment Variables
# Copy this file to .env and fill in values
# =============================================

# Server
PORT=5000
NODE_ENV=production

# MongoDB
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/vibe

# JWT
JWT_SECRET=your_super_secret_jwt_key_here

# Frontend URL (for CORS - comma separated if multiple)
FRONTEND_URL=https://your-frontend-url.netlify.app

# =============================================
# EMAIL CONFIGURATION
# Option 1 (Recommended for Render): Brevo API
# Option 2 (Fallback): Gmail SMTP
# =============================================

# --- Brevo (Render-safe, bypasses SMTP block) ---
BREVO_API_KEY=your_brevo_api_key_here
SMTP_FROM_EMAIL=your_verified_sender@yourdomain.com
SMTP_SENDER_NAME=VIBE

# --- Gmail SMTP (Fallback if no Brevo key) ---
# GMAIL_USER=youremail@gmail.com
# GMAIL_APP_PASSWORD=your_gmail_app_password

# Admin email (for support tickets)
SMTP_ADMIN_EMAIL=admin@yourdomain.com

# =============================================
# FILE UPLOADS (Cloudinary - Optional)
# =============================================
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
